# Copy this to .env.local and fill in your values.
# These are the same Supabase credentials used by the web app.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# The URL of your deployed Vercel app (or http://localhost:3000 for dev)
# This is used as the proxy for Akahu API calls.
EXPO_PUBLIC_AKAHU_PROXY_URL=https://your-app.vercel.app
